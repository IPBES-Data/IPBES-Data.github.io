/.quarto/

/docs/
/_site/

**/*.quarto_ipynb

# macOS
.DS_Store
.AppleDouble
.LSOverride
# Keep macOS special Icon files out of git, but do not ignore normal "icons" directories.
# (The old `Icon?` pattern can match `icons` on case-insensitive filesystems.)
._*
.Spotlight-V100
.Trashes
.fseventsd
